# Postgres connection string for the hosted Supabase database.
SUPABASE_DB_URL=postgresql://user:password@host:5432/postgres

# OpenAI API key used to generate the audit summary text.
OPENAI_API_KEY=

# Resend (https://resend.com) -- used to email the generated audit to the prospect.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# "stub" (default) returns randomized rank data instead of calling DataForSEO.
RANK_API_MODE=stub
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# "stub" (default) returns randomized citation data instead of a real check.
CITATION_API_MODE=stub
